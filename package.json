  "keywords": [
    "css",
    "xcss",
    "styles"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "chokidar": "^4.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/node": "^22.16.3",
    "esbuild": "^0.25.8",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.26.0"
  },
  "type": "module"
}