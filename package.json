{
  "name": "xcss-engine",
  "description": "A future-proof CSS-DSL abtration layer with native AI-support.",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yshell-dev/xcss"
  },
  "bin": {
    "xdev": "./execute/javascript/main.js",
    "xrun": "./run/_gorun.js",
    "xbin": "./bin/_test_",
    "xcss": "./run/script.js"
  },
  "funding": {
    "type": "individual",
    "url": "https://yshell.dev/xcss/funding/"
  },
  "scripts": {
    "install": "node ./run/install.js",
    "ts:compile": "tsc -p ./typescript",
    "es:compile": "node ./execute/script/esbuild.js",
    "go:test": "go build -o ./bin/_test_ ./go/package.go",
    "go:stats": "chmod +x ./run/_data.sh && ./run/_data.sh go",
    "go:package": "chmod +x ./run/_build.sh && ./run/_build.sh",
    "dev:publish": "node ./execute/script/publish.js"
  },
  "bugs": {
    "url": "https://github.com/yshell-dev/xcss-online/issues"
  },
