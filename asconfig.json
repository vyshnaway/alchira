{
    "targets": {
        "debug": {
            "outFile": "binary/debug.wasm",
            "textFile": "binary/debug.wat",
            "sourceMap": true,
            "debug": true
        },
        "release": {
            "outFile": "binary/xcss.wasm",
            "textFile": "binary/xcss.wat",
            "sourceMap": true,
            "optimizeLevel": 3,
            "shrinkLevel": 2,
            "converge": false,
            "noAssert": false
        }
    },
    "options": {
        "bindings": "esm",
        "strict": true,
        "importMemory": true,
        "initialMemory": 100,
        "maximumMemory": 1024,
        "noExportMemory": false
    }
}